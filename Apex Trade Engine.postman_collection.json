				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    // The response body is the raw JWT string",
									"    pm.environment.set(\"jwt_token\", pm.response.text());",
									"    console.log(\"Token set successfully\");",
									"}",
									"",
									"pm.test(\"Response status code is 200\", function () {",
									"    pm.expect(pm.response.code).to.equal(200);",
									"});",
									"",
									"",
									"pm.test(\"Response time is less than 200ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(200);",
									"});",
									"",
									"",
									"pm.test(\"Response content type is text/plain\", function () {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.eql('text/plain');",
									"});",
									"",
									"",
									"pm.test(\"Response body is a valid JWT token format\", function () {",
									"    const responseBody = pm.response.text();",
									"    const jwtPattern = /^[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+\\.[A-Za-z0-9-_]+$/;",
									"",
									"    pm.expect(responseBody).to.match(jwtPattern, \"Response body should match JWT format\");",
									"});",
									"",
									"",
									"pm.test(\"JWT token contains the required three parts\", function () {",
									"    const responseData = pm.response.text();",
									"    const tokenParts = responseData.split('.');",
									"",
									"    pm.expect(tokenParts).to.have.lengthOf(3, \"Token should contain three parts: header, payload, and signature\");",
									"});",
									"",
									""
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
